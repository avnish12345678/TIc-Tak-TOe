# Nakama HTTP + WebSocket (same host/port as browser can reach)
VITE_NAKAMA_HOST=localhost
VITE_NAKAMA_PORT=7350
# Must match Nakama --socket.server_key (default in docker-compose: defaultkey)
VITE_NAKAMA_SERVER_KEY=defaultkey
# Set true only when the API is served over HTTPS/WSS
VITE_NAKAMA_USE_SSL=false

# In dev, false = call Nakama directly on VITE_NAKAMA_HOST:PORT (needs CORS on Nakama). Default true = use Vite proxy.
# VITE_NAKAMA_USE_VITE_PROXY=true
